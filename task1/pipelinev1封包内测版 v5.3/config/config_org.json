{
  "project": {
    "name": "需求结构化分析工具",
    "version": "5.3.0",
    "description": "基于AC范式的需求结构化分析工具"
  },
  "llm": {
    "providers": {
      "LLM-1-S": {
        "api_key": "1",
        "api_base": "https://ark.cn-beijing.volces.com/api/v3",
        "model": "doubao-seed-2-0-pro-260215",
        "temperature": 0.7,
        "max_tokens": 8192,
        "timeout": 300
      },
      "LLM-2-G": {
        "api_key": "1",
        "api_base": "https://open.cherryin.cc/v1",
        "model": "google/gemini-3.1-pro-preview",
        "temperature": 0.7,
        "max_tokens": 8192,
        "timeout": 300
      },
      "LLM-3-Q": {
        "api_key": "1",
        "api_base": "https://dashscope.aliyuncs.com/compatible-mode/v1",
        "model": "qwen3.5-plus",
        "temperature": 0.7,
        "max_tokens": 8192,
        "timeout": 300
      }
    },
    "default_provider": "LLM-1-S"
  },
  "workspace": {
    "root_dir": "workspace",
    "data_dir": "workspace/data",
    "backup_dir": "workspace/backups",
    "export_dir": "workspace/exports"
  },
  "storage": {
    "auto_backup": true,
    "max_backup_count": 50,
    "content_fingerprint_algorithm": "md5"
  },
  "ui": {
    "theme": "light",
    "page_title": "需求结构化分析管道",
    "page_icon": "📊"
  }
}